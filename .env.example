# Postgres 连接串 (Neon / Vercel Postgres / 本地 Docker 皆可)
# Neon 推荐: 使用 pooled URL 作 DATABASE_URL,direct URL 作 DIRECT_URL
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# 用 `openssl rand -base64 32` 生成
AUTH_SECRET="change-me-to-a-random-string"

# 部署到 Vercel 后填写,如 https://your-app.vercel.app
# 本地开发可留空
AUTH_URL=""

# 初始管理员账号 (运行 npm run db:seed 时会创建)
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="please-change-me"
SEED_ADMIN_DISPLAY_NAME="管理员"

# Excel 导入文件路径 (相对项目根目录或绝对路径)
IMPORT_XLSX_PATH="../7. 🏋️日高生＋海外高中非留学签证报考条件筛选表.xlsx"
